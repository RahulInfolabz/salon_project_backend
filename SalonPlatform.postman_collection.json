          "request": { "method": "POST", "url": { "raw": "{{base_url}}/admin/closeInquiry/INQUIRY_ID_HERE", "host": ["{{base_url}}"], "path": ["admin", "closeInquiry", "INQUIRY_ID_HERE"] } }
