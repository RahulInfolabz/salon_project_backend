            "url": { "raw": "{{base_url}}/admin/updateBooking", "host": ["{{base_url}}"], "path": ["admin", "updateBooking"] },
            "body": { "mode": "raw", "raw": "{\n  \"id\": \"BOOKING_ID_HERE\",\n  \"time_slot\": \"10:00 AM\",\n  \"booking_status\": \"Approved\"\n}" }
          }
        },
        {
          "name": "Get All Payments",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/payments", "host": ["{{base_url}}"], "path": ["admin", "payments"] } }
        },
        {
          "name": "Get All Feedbacks (Admin)",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/feedbacks", "host": ["{{base_url}}"], "path": ["admin", "feedbacks"] } }
        },
        {
          "name": "Get All Inquiries",
          "request": { "method": "GET", "url": { "raw": "{{base_url}}/admin/inquiries", "host": ["{{base_url}}"], "path": ["admin", "inquiries"] } }
        },
        {
